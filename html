<!-- calendar.html - Календарь с событиями на JavaScript -->
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Календарь событий</title>
    <style>
        * { box-sizing: border-box; font-family: 'Segoe UI', system-ui; }
        body { background: #e9ecef; margin: 0; padding: 20px; }
        .container { max-width: 1200px; margin: auto; background: white; border-radius: 24px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.1); }
        .header { background: #2c3e50; color: white; padding: 15px 20px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; }
        .nav button { background: #3498db; border: none; color: white; padding: 8px 16px; margin: 0 5px; border-radius: 30px; cursor: pointer; }
        .search input { padding: 8px; border-radius: 30px; border: none; width: 200px; }
        .main { display: flex; flex-wrap: wrap; }
        .calendar { flex: 3; padding: 20px; }
        .events { flex: 1; background: #f8f9fa; padding: 20px; border-left: 1px solid #dee2e6; }
        .weekdays { display: grid; grid-template-columns: repeat(7, 1fr); text-align: center; font-weight: bold; margin-bottom: 10px; }
        .days { display: grid; grid-template-columns: repeat(7, 1fr); gap: 5px; }
        .day { background: white; border: 1px solid #ddd; border-radius: 12px; padding: 12px 5px; text-align: center; cursor: pointer; transition: 0.1s; min-height: 80px; position: relative; }
        .day:hover { background: #e3f2fd; transform: scale(0.98); }
        .day.today { background: #fff3cd; border-color: #ffc107; }
        .day.selected { background: #cfe2ff; border-color: #0d6efd; }
        .event-indicator { font-size: 18px; position: absolute; bottom: 5px; right: 8px; }
        .event-item { background: white; margin: 8px 0; padding: 8px; border-radius: 12px; border-left: 4px solid #3498db; cursor: pointer; }
        .event-item:hover { background: #e9ecef; }
        button { background: #28a745; color: white; border: none; padding: 8px 16px; border-radius: 30px; cursor: pointer; margin-top: 10px; }
        .delete-btn { background: #dc3545; }
        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); justify-content: center; align-items: center; }
        .modal-content { background: white; padding: 20px; border-radius: 24px; width: 400px; }
        .modal-content input, .modal-content textarea { width: 100%; margin: 8px 0; padding: 8px; border-radius: 12px; border: 1px solid #ccc; }
        @media (max-width: 768px) { .main { flex-direction: column; } .events { border-left: none; border-top: 1px solid #dee2e6; } }
    </style>
</head>
<body>
<div class="container">
    <div class="header">
        <div class="nav">
            <button id="prevMonth">◀</button>
            <span id="monthYear" style="margin: 0 15px; font-weight: bold;"></span>
            <button id="nextMonth">▶</button>
            <button id="todayBtn">Сегодня</button>
        </div>
        <div class="search">
            <input type="text" id="searchInput" placeholder="Поиск событий...">
            <button id="searchBtn">🔍</button>
        </div>
    </div>
    <div class="main">
        <div class="calendar">
            <div class="weekdays" id="weekdays"></div>
            <div class="days" id="daysGrid"></div>
        </div>
        <div class="events">
            <h3>События на <span id="selectedDateLabel"></span></h3>
            <div id="eventsList"></div>
            <button id="addEventBtn">➕ Добавить событие</button>
        </div>
    </div>
</div>
<div id="eventModal" class="modal">
    <div class="modal-content">
        <h3 id="modalTitle">Событие</h3>
        <input type="text" id="eventTime" placeholder="Время (ЧЧ:ММ)">
        <input type="text" id="eventTitle" placeholder="Название *">
        <textarea id="eventDesc" rows="3" placeholder="Описание"></textarea>
        <input type="hidden" id="eventIndex">
        <button id="saveEventBtn">Сохранить</button>
        <button id="cancelModalBtn">Отмена</button>
    </div>
</div>
<script>
    let currentDate = new Date();
    let events = JSON.parse(localStorage.getItem('calendarEvents') || '{}');
    let selectedDateStr = null;
    let editingIndex = -1;

    const monthNames = ['Январь', 'Февраль', 'Март', 'Апрель', 'Май', 'Июнь', 'Июль', 'Август', 'Сентябрь', 'Октябрь', 'Ноябрь', 'Декабрь'];
    const weekdays = ['Пн', 'Вт', 'Ср', 'Чт', 'Пт', 'Сб', 'Вс'];

    function saveEvents() { localStorage.setItem('calendarEvents', JSON.stringify(events)); }

    function renderCalendar() {
        const year = currentDate.getFullYear();
        const month = currentDate.getMonth();
        const firstDay = new Date(year, month, 1);
        const startWeekday = firstDay.getDay(); // 0 воскресенье -> преобразуем в понедельник как 0
        let startOffset = (startWeekday === 0 ? 6 : startWeekday - 1);
        const daysInMonth = new Date(year, month + 1, 0).getDate();
        const today = new Date();
        
        document.getElementById('monthYear').innerText = `${monthNames[month]} ${year}`;
        
        const daysGrid = document.getElementById('daysGrid');
        daysGrid.innerHTML = '';
        for (let i = 0; i < 42; i++) {
            const dayNum = i - startOffset + 1;
            if (dayNum > 0 && dayNum <= daysInMonth) {
                const dateObj = new Date(year, month, dayNum);
                const dateStr = dateObj.toISOString().split('T')[0];
                const isToday = (dateObj.toDateString() === today.toDateString());
                const hasEvents = events[dateStr] && events[dateStr].length > 0;
                const div = document.createElement('div');
                div.className = `day ${isToday ? 'today' : ''} ${selectedDateStr === dateStr ? 'selected' : ''}`;
                div.innerHTML = `<div>${dayNum}</div>${hasEvents ? '<div class="event-indicator">📌</div>' : ''}`;
                div.onclick = () => selectDate(dateStr);
                daysGrid.appendChild(div);
            } else {
                const empty = document.createElement('div');
                empty.className = 'day';
                empty.style.background = '#f8f9fa';
                daysGrid.appendChild(empty);
            }
        }
        // weekdays header
        const weekdaysDiv = document.getElementById('weekdays');
        weekdaysDiv.innerHTML = weekdays.map(d => `<div>${d}</div>`).join('');
    }

    function selectDate(dateStr) {
        selectedDateStr = dateStr;
        renderCalendar();
        document.getElementById('selectedDateLabel').innerText = dateStr;
        renderEvents();
    }

    function renderEvents() {
        const container = document.getElementById('eventsList');
        container.innerHTML = '';
        if (!selectedDateStr || !events[selectedDateStr]) {
            container.innerHTML = '<p>Нет событий</p>';
            return;
        }
        events[selectedDateStr].forEach((ev, idx) => {
            const div = document.createElement('div');
            div.className = 'event-item';
            div.innerHTML = `<strong>${ev.time || ''}</strong> ${ev.title}<br><small>${ev.desc || ''}</small>
                             <div><button class="editEvent" data-idx="${idx}">✏️</button>
                             <button class="deleteEvent" data-idx="${idx}">🗑</button></div>`;
            container.appendChild(div);
        });
        document.querySelectorAll('.editEvent').forEach(btn => {
            btn.onclick = (e) => { e.stopPropagation(); editEvent(parseInt(btn.dataset.idx)); };
        });
        document.querySelectorAll('.deleteEvent').forEach(btn => {
            btn.onclick = (e) => { e.stopPropagation(); deleteEvent(parseInt(btn.dataset.idx)); };
        });
    }

    function addEvent() {
        editingIndex = -1;
        document.getElementById('modalTitle').innerText = 'Добавить событие';
        document.getElementById('eventTime').value = '';
        document.getElementById('eventTitle').value = '';
        document.getElementById('eventDesc').value = '';
        document.getElementById('eventModal').style.display = 'flex';
    }

    function editEvent(idx) {
        if (!selectedDateStr) return;
        const ev = events[selectedDateStr][idx];
        editingIndex = idx;
        document.getElementById('modalTitle').innerText = 'Редактировать событие';
        document.getElementById('eventTime').value = ev.time || '';
        document.getElementById('eventTitle').value = ev.title;
        document.getElementById('eventDesc').value = ev.desc || '';
        document.getElementById('eventModal').style.display = 'flex';
    }

    function deleteEvent(idx) {
        if (!selectedDateStr) return;
        if (confirm('Удалить событие?')) {
            events[selectedDateStr].splice(idx, 1);
            if (events[selectedDateStr].length === 0) delete events[selectedDateStr];
            saveEvents();
            renderEvents();
            renderCalendar();
        }
    }

    function saveEventModal() {
        const time = document.getElementById('eventTime').value.trim();
        const title = document.getElementById('eventTitle').value.trim();
        if (!title) { alert('Название обязательно'); return; }
        const desc = document.getElementById('eventDesc').value.trim();
        if (!selectedDateStr) { alert('Выберите дату'); return; }
        if (!events[selectedDateStr]) events[selectedDateStr] = [];
        const eventData = { time, title, desc };
        if (editingIndex >= 0) {
            events[selectedDateStr][editingIndex] = eventData;
        } else {
            events[selectedDateStr].push(eventData);
        }
        saveEvents();
        document.getElementById('eventModal').style.display = 'none';
        renderEvents();
        renderCalendar();
    }

    function searchEvents() {
        const keyword = document.getElementById('searchInput').value.trim().toLowerCase();
        if (!keyword) { alert('Введите ключевое слово'); return; }
        let results = [];
        for (let date in events) {
            events[date].forEach(ev => {
                if (ev.title.toLowerCase().includes(keyword) || (ev.desc && ev.desc.toLowerCase().includes(keyword))) {
                    results.push(`${date}: ${ev.time} ${ev.title}`);
                }
            });
        }
        if (results.length) alert('Результаты:\n' + results.slice(0,20).join('\n'));
        else alert('Ничего не найдено');
    }

    document.getElementById('prevMonth').onclick = () => { currentDate.setMonth(currentDate.getMonth()-1); renderCalendar(); };
    document.getElementById('nextMonth').onclick = () => { currentDate.setMonth(currentDate.getMonth()+1); renderCalendar(); };
    document.getElementById('todayBtn').onclick = () => { currentDate = new Date(); renderCalendar(); };
    document.getElementById('addEventBtn').onclick = addEvent;
    document.getElementById('saveEventBtn').onclick = saveEventModal;
    document.getElementById('cancelModalBtn').onclick = () => document.getElementById('eventModal').style.display = 'none';
    document.getElementById('searchBtn').onclick = searchEvents;
    window.onclick = (e) => { if (e.target === document.getElementById('eventModal')) document.getElementById('eventModal').style.display = 'none'; };
    renderCalendar();
    // Если дата не выбрана, выбираем сегодняшнюю
    const todayStr = new Date().toISOString().split('T')[0];
    selectDate(todayStr);
</script>
</body>
</html>
