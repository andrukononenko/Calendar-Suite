"""
calendar.py - Календарь с событиями на Python (Tkinter)
"""

import tkinter as tk
from tkinter import ttk, messagebox, simpledialog
import json
import os
from datetime import datetime, timedelta
from calendar import monthrange, month_name, day_name

DATA_FILE = "events.json"

class CalendarApp:
    def __init__(self, root):
        self.root = root
        self.root.title("Календарь с событиями")
        self.root.geometry("900x600")
        self.root.configure(bg="#f0f0f0")
        
        self.current_year = datetime.now().year
        self.current_month = datetime.now().month
        self.events = self.load_events()
        
        self.create_widgets()
        self.draw_calendar()
        
    def load_events(self):
        if os.path.exists(DATA_FILE):
            with open(DATA_FILE, "r", encoding="utf-8") as f:
                return json.load(f)
        return {}
    
    def save_events(self):
        with open(DATA_FILE, "w", encoding="utf-8") as f:
            json.dump(self.events, f, indent=2, ensure_ascii=False)
    
    def create_widgets(self):
        # Верхняя панель с навигацией
        nav_frame = tk.Frame(self.root, bg="#2c3e50", height=60)
        nav_frame.pack(fill=tk.X)
        nav_frame.pack_propagate(False)
        
        self.month_year_label = tk.Label(nav_frame, font=("Arial", 16, "bold"), bg="#2c3e50", fg="white")
        self.month_year_label.pack(side=tk.LEFT, padx=20, pady=10)
        
        btn_prev = tk.Button(nav_frame, text="◀", command=self.prev_month, font=("Arial", 12), bg="#3498db", fg="white", width=4)
        btn_prev.pack(side=tk.LEFT, padx=5)
        btn_next = tk.Button(nav_frame, text="▶", command=self.next_month, font=("Arial", 12), bg="#3498db", fg="white", width=4)
        btn_next.pack(side=tk.LEFT, padx=5)
        
        btn_today = tk.Button(nav_frame, text="Сегодня", command=self.go_today, font=("Arial", 10), bg="#2ecc71", fg="white")
        btn_today.pack(side=tk.LEFT, padx=10)
        
        # Поле поиска
        tk.Label(nav_frame, text="Поиск:", bg="#2c3e50", fg="white").pack(side=tk.LEFT, padx=(20,5))
        self.search_entry = tk.Entry(nav_frame, width=20)
        self.search_entry.pack(side=tk.LEFT, padx=5)
        self.search_entry.bind("<Return>", lambda e: self.search_events())
        btn_search = tk.Button(nav_frame, text="🔍", command=self.search_events, bg="#f39c12", fg="white")
        btn_search.pack(side=tk.LEFT)
        
        # Основная область: календарь (слева) и список событий (справа)
        main_frame = tk.Frame(self.root)
        main_frame.pack(fill=tk.BOTH, expand=True, padx=10, pady=10)
        
        # Левая часть - сетка календаря
        self.calendar_frame = tk.Frame(main_frame, bg="white", relief=tk.RAISED, bd=1)
        self.calendar_frame.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)
        
        # Правая часть - события
        right_frame = tk.Frame(main_frame, width=250, bg="#ecf0f1")
        right_frame.pack(side=tk.RIGHT, fill=tk.Y, padx=(10,0))
        right_frame.pack_propagate(False)
        
        tk.Label(right_frame, text="События на выбранную дату", font=("Arial", 12, "bold"), bg="#ecf0f1").pack(pady=5)
        self.event_listbox = tk.Listbox(right_frame, height=20, width=35)
        self.event_listbox.pack(fill=tk.BOTH, expand=True, padx=5, pady=5)
        self.event_listbox.bind("<<ListboxSelect>>", self.on_event_select)
        
        btn_add = tk.Button(right_frame, text="➕ Добавить событие", command=self.add_event, bg="#2ecc71", fg="white")
        btn_add.pack(pady=5, fill=tk.X, padx=5)
        btn_edit = tk.Button(right_frame, text="✏️ Редактировать", command=self.edit_event, bg="#3498db", fg="white")
        btn_edit.pack(pady=5, fill=tk.X, padx=5)
        btn_delete = tk.Button(right_frame, text="🗑 Удалить", command=self.delete_event, bg="#e74c3c", fg="white")
        btn_delete.pack(pady=5, fill=tk.X, padx=5)
        
        self.selected_date = None
        self.selected_event_index = None
        
    def draw_calendar(self):
        for widget in self.calendar_frame.winfo_children():
            widget.destroy()
        
        # Заголовок с днями недели
        days = ["Пн", "Вт", "Ср", "Чт", "Пт", "Сб", "Вс"]
        for i, day in enumerate(days):
            lbl = tk.Label(self.calendar_frame, text=day, font=("Arial", 10, "bold"), bg="#bdc3c7", width=8, height=2, relief=tk.RIDGE)
            lbl.grid(row=0, column=i, sticky="nsew")
        
        first_day, num_days = monthrange(self.current_year, self.current_month)
        # Первый день недели в понедельник? monthrange возвращает 0=пн, 1=вт... 6=вс
        start_col = first_day  # 0=понедельник, 6=воскресенье
        row = 1
        day = 1
        self.calendar_buttons = {}
        
        for i in range(6):
            for j in range(7):
                if i == 0 and j < start_col:
                    continue
                if day > num_days:
                    break
                date_obj = datetime(self.current_year, self.current_month, day)
                date_str = date_obj.strftime("%Y-%m-%d")
                has_event = "📌" if date_str in self.events and self.events[date_str] else ""
                btn_text = f"{day}\n{has_event}"
                btn = tk.Button(self.calendar_frame, text=btn_text, font=("Arial", 9), width=8, height=3,
                                command=lambda d=day: self.show_events_for_date(d),
                                bg="white", relief=tk.RAISED)
                btn.grid(row=row, column=j, sticky="nsew", padx=1, pady=1)
                self.calendar_buttons[date_str] = btn
                day += 1
                if day > num_days:
                    break
            if day > num_days:
                break
            row += 1
        
        # Настройка веса столбцов и строк
        for i in range(7):
            self.calendar_frame.columnconfigure(i, weight=1)
        for i in range(1, row+1):
            self.calendar_frame.rowconfigure(i, weight=1)
        
        self.month_year_label.config(text=f"{month_name[self.current_month]} {self.current_year}")
        self.update_event_indicators()
    
    def update_event_indicators(self):
        for date_str, btn in self.calendar_buttons.items():
            day_num = int(date_str.split("-")[2])
            has_event = "📌" if date_str in self.events and self.events[date_str] else ""
            btn.config(text=f"{day_num}\n{has_event}")
    
    def show_events_for_date(self, day):
        date_str = f"{self.current_year}-{self.current_month:02d}-{day:02d}"
        self.selected_date = date_str
        self.event_listbox.delete(0, tk.END)
        events = self.events.get(date_str, [])
        for idx, ev in enumerate(events):
            time_str = ev.get("time", "")
            title = ev.get("title", "Без названия")
            desc = ev.get("desc", "")
            self.event_listbox.insert(tk.END, f"{time_str} {title} - {desc[:30]}")
        self.selected_event_index = None
    
    def on_event_select(self, event):
        selection = self.event_listbox.curselection()
        if selection:
            self.selected_event_index = selection[0]
    
    def add_event(self):
        if not self.selected_date:
            messagebox.showwarning("Предупреждение", "Сначала выберите дату в календаре")
            return
        dialog = EventDialog(self.root, "Добавить событие")
        self.root.wait_window(dialog.dialog)
        if dialog.result:
            time_str, title, desc = dialog.result
            if self.selected_date not in self.events:
                self.events[self.selected_date] = []
            self.events[self.selected_date].append({"time": time_str, "title": title, "desc": desc})
            self.save_events()
            self.show_events_for_date(int(self.selected_date.split("-")[2]))
            self.update_event_indicators()
    
    def edit_event(self):
        if not self.selected_date or self.selected_event_index is None:
            messagebox.showwarning("Предупреждение", "Выберите событие из списка")
            return
        events = self.events.get(self.selected_date, [])
        if self.selected_event_index >= len(events):
            return
        ev = events[self.selected_event_index]
        dialog = EventDialog(self.root, "Редактировать событие", ev.get("time",""), ev.get("title",""), ev.get("desc",""))
        self.root.wait_window(dialog.dialog)
        if dialog.result:
            time_str, title, desc = dialog.result
            events[self.selected_event_index] = {"time": time_str, "title": title, "desc": desc}
            self.save_events()
            self.show_events_for_date(int(self.selected_date.split("-")[2]))
            self.update_event_indicators()
    
    def delete_event(self):
        if not self.selected_date or self.selected_event_index is None:
            messagebox.showwarning("Предупреждение", "Выберите событие")
            return
        if messagebox.askyesno("Удаление", "Удалить выбранное событие?"):
            events = self.events.get(self.selected_date, [])
            if self.selected_event_index < len(events):
                events.pop(self.selected_event_index)
                if not events:
                    del self.events[self.selected_date]
                else:
                    self.events[self.selected_date] = events
                self.save_events()
                self.show_events_for_date(int(self.selected_date.split("-")[2]))
                self.update_event_indicators()
    
    def search_events(self):
        keyword = self.search_entry.get().strip().lower()
        if not keyword:
            messagebox.showinfo("Поиск", "Введите ключевое слово")
            return
        results = []
        for date_str, ev_list in self.events.items():
            for ev in ev_list:
                if keyword in ev.get("title", "").lower() or keyword in ev.get("desc", "").lower():
                    results.append(f"{date_str}: {ev['time']} {ev['title']}")
        if results:
            messagebox.showinfo("Результаты поиска", "\n".join(results[:20]))
        else:
            messagebox.showinfo("Поиск", "Ничего не найдено")
    
    def prev_month(self):
        if self.current_month == 1:
            self.current_month = 12
            self.current_year -= 1
        else:
            self.current_month -= 1
        self.draw_calendar()
    
    def next_month(self):
        if self.current_month == 12:
            self.current_month = 1
            self.current_year += 1
        else:
            self.current_month += 1
        self.draw_calendar()
    
    def go_today(self):
        self.current_year = datetime.now().year
        self.current_month = datetime.now().month
        self.draw_calendar()

class EventDialog:
    def __init__(self, parent, title, time="", name="", desc=""):
        self.dialog = tk.Toplevel(parent)
        self.dialog.title(title)
        self.dialog.geometry("400x250")
        self.dialog.transient(parent)
        self.dialog.grab_set()
        
        tk.Label(self.dialog, text="Время (ЧЧ:ММ):").pack(pady=5)
        self.time_entry = tk.Entry(self.dialog, width=20)
        self.time_entry.insert(0, time)
        self.time_entry.pack()
        
        tk.Label(self.dialog, text="Название:").pack(pady=5)
        self.title_entry = tk.Entry(self.dialog, width=40)
        self.title_entry.insert(0, name)
        self.title_entry.pack()
        
        tk.Label(self.dialog, text="Описание:").pack(pady=5)
        self.desc_entry = tk.Text(self.dialog, height=5, width=40)
        self.desc_entry.insert("1.0", desc)
        self.desc_entry.pack()
        
        btn_frame = tk.Frame(self.dialog)
        btn_frame.pack(pady=10)
        tk.Button(btn_frame, text="OK", command=self.ok, bg="#2ecc71", fg="white").pack(side=tk.LEFT, padx=10)
        tk.Button(btn_frame, text="Отмена", command=self.cancel, bg="#e74c3c", fg="white").pack(side=tk.LEFT)
        
        self.result = None
    
    def ok(self):
        time_val = self.time_entry.get().strip()
        title_val = self.title_entry.get().strip()
        if not title_val:
            messagebox.showerror("Ошибка", "Название обязательно")
            return
        desc_val = self.desc_entry.get("1.0", tk.END).strip()
        self.result = (time_val, title_val, desc_val)
        self.dialog.destroy()
    
    def cancel(self):
        self.dialog.destroy()

if __name__ == "__main__":
    root = tk.Tk()
    app = CalendarApp(root)
    root.mainloop()
